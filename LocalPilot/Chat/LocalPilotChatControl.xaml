<UserControl x:Class="LocalPilot.Chat.LocalPilotChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400"
             FontFamily="Segoe UI" FontSize="13">

    <UserControl.Resources>
        <!-- ═══ Theme Colors (Dynamic mapping to VS Shell) ═══ -->
        <SolidColorBrush x:Key="LpWindowBgBrush"      Color="Transparent"/>
        <SolidColorBrush x:Key="LpWindowFgBrush"      Color="Transparent"/>
        <SolidColorBrush x:Key="LpMenuBgBrush"        Color="Transparent"/>
        <SolidColorBrush x:Key="LpMenuBorderBrush"    Color="Transparent"/>
        <SolidColorBrush x:Key="LpHoverBgBrush"       Color="Transparent"/>
        <SolidColorBrush x:Key="LpHoverFgBrush"       Color="Transparent"/>
        <SolidColorBrush x:Key="LpMutedFgBrush"       Color="Transparent"/>
        <SolidColorBrush x:Key="LpAccentBrush"        Color="Transparent"/>
        <SolidColorBrush x:Key="LpAccentHoverBrush"   Color="Transparent"/>
        <SolidColorBrush x:Key="LpSendIconBrush"      Color="White"/>
        <SolidColorBrush x:Key="LpUserBubbleBgBrush"  Color="Transparent"/>
        <SolidColorBrush x:Key="LpSelectionBrush"     Color="Transparent"/>

        <SolidColorBrush x:Key="LpCodeKwBrush"        Color="Transparent"/>
        <SolidColorBrush x:Key="LpCodeCommentBrush"   Color="Transparent"/>
        <SolidColorBrush x:Key="LpCodeStringBrush"    Color="Transparent"/>
        <SolidColorBrush x:Key="LpAntigravityBlue"   Color="#2D8CFF"/>
        <!-- Solid surfaces for code / banners (filled in UpdateBrushes — no alpha) -->
        <SolidColorBrush x:Key="LpCodeHeaderBgBrush"   Color="Transparent"/>
        <SolidColorBrush x:Key="LpCodeContentBgBrush" Color="Transparent"/>
        <SolidColorBrush x:Key="LpBannerBgBrush"     Color="Transparent"/>

        <!-- ═══ Minimalist Scrollbar ═══ -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width"      Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="Transparent"/>
            </Style.Resources>
        </Style>

        <!-- ═══ Professional Button Style — clean, borderless, theme-aware hover ═══ -->
        <Style x:Key="LpButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource LpAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Ghost Icon Button (Sexy & Professional) ═══ -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpMutedFgBrush}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Margin"          Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="4">
                            <ContentPresenter x:Name="Cp" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="2"
                                              RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="Cp" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Modern Chat Input — sleek border, integrated look ═══ -->
        <Style x:Key="ChatInputStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource LpAccentBrush}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource LpSelectionBrush}"/>
            <Setter Property="SelectionOpacity" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <!-- 💎 Minimalist Placeholder -->
                            <TextBlock x:Name="Placeholder"
                                       Text="Ask anything"
                                       Foreground="{DynamicResource LpMutedFgBrush}"
                                       VerticalAlignment="Top"
                                       IsHitTestVisible="False"
                                       Margin="14,10,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value=""/>
                                                    <Condition Binding="{Binding IsFocused, RelativeSource={RelativeSource TemplatedParent}}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <!-- 🎯 Standard Content Host (Preserves Caret & Selection) -->
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Background="Transparent"
                                          Margin="0"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Context Menu (Themed) ────────────────────────────────── -->
        <Style x:Key="ThemedContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource LpMenuBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="200"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ItemsPresenter Margin="0,4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Padding"    Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="4,2"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" SharedSizeGroup="IconGroup"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Modern Accent Bar (Visible only on focus/hover) -->
                                <Border x:Name="AccentBar" 
                                        Grid.Column="0" 
                                        Width="3" 
                                        Height="16" 
                                        HorizontalAlignment="Left" 
                                        Background="{DynamicResource LpAccentBrush}" 
                                        CornerRadius="2" 
                                        Visibility="Collapsed"
                                        Margin="1,0,0,0"/>

                                <!-- Icon Column -->
                                <ContentPresenter x:Name="Icon"
                                                  Grid.Column="0"
                                                  ContentSource="Icon"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="0"/>

                                <!-- Header Content -->
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  Margin="8,0,16,0"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpAccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource LpAccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="AccentBar" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource LpMutedFgBrush}"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LpMutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LpMutedFgBrush}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Opacity"    Value="1.0"/>
        </Style>

        <!-- ── Send Button (Premium Glow Aesthetic) ─────────────────────── -->
        <!-- 💼 Premium Work Summary Styles -->
        <Style x:Key="WorkSummaryHeaderStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource LpMenuBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkRowStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,4,8,4"/> <!-- Indented for hierarchy -->
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource LpMenuBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🚀 Updated Send/Action Styles -->
        <Style x:Key="LpSendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource LpAccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource LpSendIconBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"> <!-- Perfect Circle (24/2) -->
                            <ContentPresenter x:Name="Cp"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              RecognizesAccessKey="False"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2">
                                 <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="SendScale" ScaleX="1" ScaleY="1" CenterX="12" CenterY="12"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Default Hover (Not Streaming) -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                    <Condition Binding="{Binding DataContext.IsStreaming, RelativeSource={RelativeSource TemplatedParent}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Opacity" Value="1.0"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpAccentHoverBrush}"/>
                            </MultiDataTrigger>

                            <!-- Streaming Hover (Slightly Brighter Red for feedback) -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                    <Condition Binding="{Binding DataContext.IsStreaming, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </MultiDataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="SendScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                <Setter TargetName="Cp" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94" CenterX="12" CenterY="12"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpMutedFgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Confirmation Buttons (Enterprise) ───────────────────────── -->
        <Style x:Key="LpPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource LpButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource LpAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LpSecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource LpButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🏛️ Chronicle Styles (Hierarchical Activity Timeline) -->
        <Style x:Key="ActionNodeStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,2,0,4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource LpMenuBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ActionNodeIconStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource LpAccentBrush}"/>
        </Style>

        <Style x:Key="ActionNodeHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource LpMutedLabel}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="Opacity" Value="1.0"/>
        </Style>

        <!-- 🏷️ Chip Style -->
        <Style x:Key="LpChipStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource LpMenuBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,8,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource LpAccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource LpAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Input HUD Border Style (Modern focus indicator) ═══ -->
        <Style x:Key="InputHudBorderStyle" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource LpMenuBgBrush}"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource LpAccentBrush}"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="Margin" Value="-0.5"/> <!-- Prevent layout shift from thicker border -->
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource LpWindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Messages -->
            <RowDefinition Height="Auto"/>  <!-- Footer / Input -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════  HEADER  ═══════════════════════════════ -->
        <!-- Flat, VS-native header — no border radius, just a bottom divider -->
        <Border Grid.Row="0"
                Background="{DynamicResource LpMenuBgBrush}"
                BorderBrush="{DynamicResource LpMenuBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: logo + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/LocalPilot;component/Assets/Logo_Concept_Minimalist.png"
                           Width="16" Height="16" VerticalAlignment="Center"/>
                    <TextBlock Text="LocalPilot"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource LpWindowFgBrush}"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>

                </StackPanel>

                <!-- Right: icon buttons -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <Button x:Name="BtnClear"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Clear conversation"
                            Click="BtnClear_Click">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource LpMutedFgBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════  MESSAGES  ══════════════════════════════ -->
        <!-- 🚀 PERFORMANCE UPGRADE: ListBox provides native virtualization and recycling.
             ItemsControl inside a ScrollViewer disables virtualization because the scrollviewer 
             provides infinite measure height. ListBox handles its own scrolling correctly. -->
        <ListBox Grid.Row="1" x:Name="MessagesContainer"
                 Background="{DynamicResource LpWindowBgBrush}"
                 BorderThickness="0"
                 Padding="0,6"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 VirtualizingStackPanel.CacheLength="2,3"
                 VirtualizingStackPanel.CacheLengthUnit="Item"
                 HorizontalContentAlignment="Stretch">
            <ListBox.Template>
                <ControlTemplate TargetType="ListBox">
                    <ScrollViewer x:Name="ChatScroll" Focusable="false" Background="Transparent">
                        <ItemsPresenter />
                    </ScrollViewer>
                </ControlTemplate>
            </ListBox.Template>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            
            <ListBox.Items>
                <!-- Welcome prompt — Copilot style: subtle, centred, muted -->
                <ListBoxItem IsHitTestVisible="False">
                    <StackPanel x:Name="WelcomePanel">
                        <TextBlock Text="What's on your mind?"
                                   FontSize="12"
                                   Foreground="{DynamicResource LpMutedFgBrush}"
                                   Margin="24,12,24,8"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Tip: use slash actions like /explain, /fix, /review, or /test."
                                   FontSize="10"
                                   Foreground="{DynamicResource LpMutedFgBrush}"
                                   Margin="24,0,24,10"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox.Items>
        </ListBox>

        <!-- ═══════════════════════  DIAGNOSTIC CONSOLE  ═══════════════════════ -->
        <!-- Collapsible terminal-like log view -->


        <!-- ═══════════════════════  FOOTER (GHOST HUD)  ═══════════════════════ -->
        <Grid Grid.Row="2">
            <StackPanel Margin="16,0,16,16">
                <!-- Status Bar (Chronicle Phase) -->
                <Border x:Name="AgentStatusBar" Visibility="Collapsed" Margin="0,0,0,12" Padding="12,8" 
                        Background="{DynamicResource LpMenuBgBrush}" CornerRadius="6" 
                        BorderBrush="{DynamicResource LpMenuBorderBrush}" BorderThickness="1"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="Visibility" Value="Visible">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="10" To="0" Duration="0:0:0.3"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                            <TextBlock x:Name="AgentActivityIcon" Text="&#xE9CE;" 
                                       FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                       Foreground="{DynamicResource LpAccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="PulseStory">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="1.0" To="0.3" Duration="0:0:0.8"
                                                                             AutoReverse="True" RepeatBehavior="Forever"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="PulseStory"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock x:Name="TxtAgentStatus" Text="{Binding AgentTurn.StatusText}" Foreground="{DynamicResource LpWindowFgBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtAgentDetail" Text="{Binding AgentTurn.DetailText}" Foreground="{DynamicResource LpMutedFgBrush}" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Confirmation Panel -->
                <Border x:Name="ConfirmationPanel" Visibility="Collapsed" Margin="0,0,0,12" Padding="16" 
                        Background="{DynamicResource LpMenuBgBrush}" CornerRadius="10" 
                        BorderBrush="{DynamicResource LpAccentBrush}" BorderThickness="1.5"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="Visibility" Value="Visible">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4">
                                                    <DoubleAnimation.EasingFunction>
                                                        <BackEase Amplitude="0.3" EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="APPROVAL"
                                   Foreground="{DynamicResource LpMutedFgBrush}"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Permission Required" FontWeight="Bold" Foreground="{DynamicResource LpWindowFgBrush}" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TxtConfirmDetail" TextWrapping="Wrap" Foreground="{DynamicResource LpMutedFgBrush}" FontSize="13" LineHeight="18"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button x:Name="BtnDeny" Content="Deny" Click="BtnDeny_Click" Style="{StaticResource LpSecondaryActionButtonStyle}" Margin="0,0,12,0"/>
                            <Button x:Name="BtnApprove" Content="Approve" Click="BtnApprove_Click" Style="{StaticResource LpPrimaryActionButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 🚀 Build Error Auto-Fix Banner -->
                <Border x:Name="BuildErrorBanner" Visibility="Collapsed" Margin="0,0,0,12" Padding="12" 
                        Background="{DynamicResource LpErrorBgBrush}" CornerRadius="8" 
                        BorderBrush="{DynamicResource LpErrorBorderBrush}" BorderThickness="1.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                   Foreground="{DynamicResource LpErrorBorderBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Build Failed" FontWeight="Bold" 
                                       Foreground="{DynamicResource LpErrorFgBrush}" FontSize="12"/>
                            <TextBlock x:Name="TxtBuildErrorMsg" Text="Error message goes here..." 
                                       Foreground="{DynamicResource LpErrorSubFgBrush}" FontSize="11" 
                                       TextTrimming="CharacterEllipsis" MaxHeight="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Dismiss" Click="BtnDismissBuildError_Click" 
                                    Style="{StaticResource LpButtonStyle}" FontSize="10" Margin="0,0,4,0"/>
                            <Button Content="Fix with AI" Click="BtnFixBuildError_Click" 
                                    Style="{StaticResource LpPrimaryActionButtonStyle}" FontSize="11" Padding="8,4"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 🏁 Review Panel (Antigravity Style) -->
                <Border x:Name="ReviewPanel" Visibility="Collapsed" Margin="0,0,0,12" Padding="12" 
                        Background="{DynamicResource LpMenuBgBrush}" CornerRadius="10" 
                        BorderBrush="{DynamicResource LpAccentBrush}" BorderThickness="1"
                        RenderTransformOrigin="0.5,0.5">
                    <StackPanel>
                        <ItemsControl x:Name="ItemsReviewFiles">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="8,6" Background="{DynamicResource LpCodeHeaderBgBrush}" CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource LpAccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding DisplayPath}" ToolTip="{Binding FullPath}" Foreground="{DynamicResource LpWindowFgBrush}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                                <TextBlock Text="{Binding AddedCount}" Foreground="#4CAF50" FontSize="11" FontWeight="Bold" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding RemovedCount}" Foreground="#F44336" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                            <Button Grid.Column="3" 
                                                    Content="&#xE990;" 
                                                    FontFamily="Segoe MDL2 Assets" 
                                                    FontSize="14"
                                                    ToolTip="Review Changes (Diff)"
                                                    Foreground="{DynamicResource LpAccentBrush}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="4"
                                                    Cursor="Hand"
                                                    Tag="{Binding FullPath}"
                                                    Click="BtnReview_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" x:Name="border">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#20FFFFFF" TargetName="border"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtReviewSummary" Text="1 File With Changes" Foreground="{DynamicResource LpMutedFgBrush}" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnRejectAll" Content="Reject all" Click="BtnRejectAll_Click" Style="{StaticResource LpSecondaryActionButtonStyle}" Margin="0,0,12,0"/>
                                <Button x:Name="BtnAcceptAll" Content="Accept all" Click="BtnAcceptAll_Click" Style="{StaticResource LpPrimaryActionButtonStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 🚀 Floating Pill HUD -->
                <Border x:Name="InputHudBorder" Style="{StaticResource InputHudBorderStyle}">
                    <Grid>
                        <TextBox x:Name="TxtInput" Style="{StaticResource ChatInputStyle}" MinHeight="80" MaxHeight="200" 
                                 Padding="18,12,80,12" AcceptsReturn="True" TextWrapping="Wrap" PreviewKeyDown="TxtInput_PreviewKeyDown"
                                 FontSize="14"
                                 IsEnabled="{Binding IsInputEnabled}"
                                 Opacity="{Binding InputOpacity}"/>
                        
                        <StackPanel Panel.ZIndex="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10" IsHitTestVisible="True">
                            <Button x:Name="BtnQuickActions" Style="{StaticResource IconButtonStyle}" Click="BtnQuickActions_Click" Margin="0,0,0,0" Width="24" Height="24" ToolTip="Slash Actions">
                                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource LpMutedFgBrush}"/>
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="QuickActionsMenu" Style="{StaticResource ThemedContextMenuStyle}">
                                        <MenuItem Header="Explain Code" Tag="explain" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Refactor Code" Tag="refactor" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Generate Documentation" Tag="document" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Review Code" Tag="review" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Fix Issues" Tag="fix" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE74F;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Generate Unit Tests" Tag="test" Click="MenuQuickAction_Click" Style="{StaticResource ThemedMenuItemStyle}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE9DB;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                             <Button x:Name="BtnSend" Style="{StaticResource LpSendButtonStyle}" Click="BtnSend_Click" Width="24" Height="24" UseLayoutRounding="True">
                                 <Path x:Name="BtnSendIcon" Data="M12,4L10.59,5.41L16.17,11H4V13H16.17L10.59,18.59L12,20L20,12L12,4Z" 
                                       Fill="{DynamicResource LpSendIconBrush}" 
                                       Width="10" Height="10" Stretch="Uniform"
                                       SnapsToDevicePixels="True"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                <TextBlock Text="Enter to send · Shift+Enter for newline"
                           Foreground="{DynamicResource LpMutedFgBrush}"
                           FontSize="10"
                           Margin="2,8,2,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
