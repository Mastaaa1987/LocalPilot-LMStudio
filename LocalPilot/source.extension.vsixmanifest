<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0"
  xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011"
  xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
    <Metadata>
        <Identity Id="LocalPilot.d17a707d-703b-4fcd-a6f6-2ad5518c660b"
                  Version="1.9.2.0"
                  Language="en-US"
                  Publisher="FutureStackSolution" />
        <DisplayName>LocalPilot — AI Coding Assistant (Ollama)</DisplayName>
        <Description>A GitHub Copilot-style AI coding assistant for Visual Studio that runs 100% locally using Ollama. Features inline ghost-text completions, AI Chat panel, code explanation, refactoring, documentation generation, code review, fix suggestions, and unit test generation — all powered by your locally running Ollama models with no data leaving your machine.</Description>
        <MoreInfo>https://github.com/FutureStackSolution/LocalPilot</MoreInfo>
        <GettingStartedGuide>https://github.com/FutureStackSolution/LocalPilot</GettingStartedGuide>
        <Icon>Assets\Logo_Concept_Minimalist.png</Icon>
        <PreviewImage>Assets\Logo_Concept_Minimalist.png</PreviewImage>
        <Tags>AI,Ollama,Copilot,Code Completion,LLM,Local AI,Chat</Tags>
        <Preview>false</Preview>
    </Metadata>
    <Installation>
        <InstallationTarget Id="Microsoft.VisualStudio.Community" Version="[17.0, 19.0)">
            <ProductArchitecture>amd64</ProductArchitecture>
        </InstallationTarget>
        <InstallationTarget Id="Microsoft.VisualStudio.Professional" Version="[17.0, 19.0)">
            <ProductArchitecture>amd64</ProductArchitecture>
        </InstallationTarget>
        <InstallationTarget Id="Microsoft.VisualStudio.Enterprise" Version="[17.0, 19.0)">
            <ProductArchitecture>amd64</ProductArchitecture>
        </InstallationTarget>
    </Installation>
    <Dependencies>
        <Dependency Id="Microsoft.Framework.NDP" DisplayName="Microsoft .NET Framework"
                    d:Source="Manual" Version="[4.7.2,)" />
    </Dependencies>
    <Prerequisites>
        <Prerequisite Id="Microsoft.VisualStudio.Component.CoreEditor"
                      Version="[17.0, 19.0)" DisplayName="Visual Studio core editor" />
    </Prerequisites>
    <Assets>
        <Asset Type="Microsoft.VisualStudio.VsPackage"
               d:Source="Project" d:ProjectName="%CurrentProject%"
               Path="|%CurrentProject%;PkgdefProjectOutputGroup|" />
        <Asset Type="Microsoft.VisualStudio.MefComponent"
               d:Source="Project" d:ProjectName="%CurrentProject%"
               Path="|%CurrentProject%|" />
    </Assets>
</PackageManifest>
