<UserControl x:Class="LocalPilot.Options.LocalPilotOptionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="700"
             FontFamily="Segoe UI" FontSize="13">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Theme Colors (Fixed Light Theme for VS Options dialog consistency) -->
        <SolidColorBrush x:Key="LpWindowBgBrush"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LpWindowFgBrush"      Color="#1E1E1E"/>
        <SolidColorBrush x:Key="LpMenuBgBrush"        Color="#F3F3F3"/>
        <SolidColorBrush x:Key="LpMenuBorderBrush"    Color="#CCCCCC"/>
        <SolidColorBrush x:Key="LpHoverBgBrush"       Color="#D6D6D6"/>
        <SolidColorBrush x:Key="LpHoverFgBrush"       Color="#000000"/>
        <SolidColorBrush x:Key="LpMutedFgBrush"       Color="#6D6D6D"/>

        <!-- Theme-aware ContextMenu popup shell -->
        <Style x:Key="ThemedContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background"      Value="{DynamicResource LpMenuBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Theme-aware MenuItem -->
        <Style x:Key="ThemedMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="Padding"     Value="28,6,20,6"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" ContentSource="Icon"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource LpHoverBgBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource LpHoverFgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared themed right-click menu for all text inputs -->
        <ContextMenu x:Key="ThemedEditContextMenu"
                     Style="{StaticResource ThemedContextMenuStyle}"
                     Grid.IsSharedSizeScope="True">
            <MenuItem Style="{StaticResource ThemedMenuItemStyle}"
                      Header="Cut" Command="ApplicationCommands.Cut">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource LpWindowFgBrush}"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Style="{StaticResource ThemedMenuItemStyle}"
                      Header="Copy" Command="ApplicationCommands.Copy">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource LpWindowFgBrush}"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Style="{StaticResource ThemedMenuItemStyle}"
                      Header="Paste" Command="ApplicationCommands.Paste">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource LpWindowFgBrush}"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator Background="{DynamicResource LpMenuBorderBrush}"
                       Margin="4,2"/>
            <MenuItem Style="{StaticResource ThemedMenuItemStyle}"
                      Header="Select All" Command="ApplicationCommands.SelectAll">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8B3;" FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource LpWindowFgBrush}"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <Style x:Key="LpInputStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource LpWindowBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="8,5"/>
            <Setter Property="Height"            Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"        Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="ContextMenu"       Value="{StaticResource ThemedEditContextMenu}"/>
        </Style>

        <Style x:Key="LpSectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Margin"       Value="0,16,0,6"/>
        </Style>

        <Style x:Key="LpLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Margin"       Value="0,0,0,3"/>
        </Style>

        <Style x:Key="LpMutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LpMutedFgBrush}"/>
            <Setter Property="FontSize"     Value="12"/>
        </Style>

        <Style x:Key="LpCheckStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="Margin"       Value="0,4,0,4"/>
        </Style>

        <Style x:Key="LpPrimaryBtn" TargetType="Button">
            <Setter Property="Background"    Value="#7C6AF7"/>
            <Setter Property="Foreground"    Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="16,7"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#9B8FFB"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#5E4FDB"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LpSecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource LpWindowBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.7"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LpSepStyle" TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource LpMenuBorderBrush}"/>
            <Setter Property="Margin"       Value="0,4,0,4"/>
        </Style>

        <!-- ═══ TabControl Premium Styling ═══ -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,20,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" IsItemsHost="True" Panel.ZIndex="1"/>
                            <Border Grid.Row="1" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter ContentSource="SelectedContent" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource LpMutedFgBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,0,24,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Background="Transparent">
                            <StackPanel>
                                <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border x:Name="Indicator" Height="3" Background="Transparent" SnapsToDevicePixels="True" 
                                        CornerRadius="1.5" Margin="0,-4,24,0"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
                                <Setter TargetName="Indicator" Property="Background" Value="#7C6AF7"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="{DynamicResource LpWindowFgBrush}"/>
                                <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource LpHoverBgBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="{DynamicResource LpWindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Tabs -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="24,20,24,0">
            <!-- ═══ Header ════════════════════════════════════════════════════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="/LocalPilot;component/Assets/Logo_Concept_Minimalist.png" 
                           Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="LocalPilot" Foreground="{DynamicResource LpWindowFgBrush}" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Local AI Assistant" Style="{DynamicResource LpMutedLabel}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Connection Status Badge -->
                <Border Grid.Column="1" VerticalAlignment="Center"
                        Background="{DynamicResource LpWindowBgBrush}"
                        BorderBrush="{DynamicResource LpMenuBorderBrush}"
                        BorderThickness="1" CornerRadius="20" Padding="12,6">
                    <StackPanel Orientation="Horizontal" Background="Transparent" VerticalAlignment="Center" Margin="0,4,0,0">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#4EC9B0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="Ollama Connected" Foreground="{DynamicResource LpWindowFgBrush}" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
            <Separator Style="{DynamicResource LpSepStyle}" Margin="0,0,0,0"/>
        </StackPanel>

        <!-- ═══ Content Tabs ═══════════════════════════════════════════════ -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="24,0,24,0">
            <!-- ───────────────── GENERAL TAB ───────────────── -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                    <StackPanel>
                        <!-- Connection -->
                        <TextBlock Text="🔗  Connection" Style="{DynamicResource LpSectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Ollama Base URL" Style="{DynamicResource LpLabelStyle}"/>
                                <TextBox x:Name="TxtBaseUrl" Style="{DynamicResource LpInputStyle}" ToolTip="Default: http://localhost:11434"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                                <Button Content="Test Connection" Style="{DynamicResource LpSecondaryBtn}" x:Name="BtnTestConnection" Click="BtnTestConnection_Click" Height="32"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="TxtConnectionResult" Foreground="#4EC9B0" FontSize="11" Margin="0,4,0,0" Visibility="Collapsed"/>

                        <!-- Core Models -->
                        <TextBlock Text="🤖  Core Models" Style="{DynamicResource LpSectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,10">
                                <TextBlock Text="Inline Completion Model" Style="{DynamicResource LpLabelStyle}"/>
                                <ComboBox x:Name="CmbCompletionModel" Height="28"/></StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="Chat Model" Style="{DynamicResource LpLabelStyle}"/>
                                <ComboBox x:Name="CmbChatModel" Height="28"/></StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,10">
                                <TextBlock Text="Embedding Model (RAG / Semantic Search)" Style="{DynamicResource LpLabelStyle}"/>
                                <ComboBox x:Name="CmbEmbeddingModel" Height="28" ToolTip="Used for semantic indexing and vector search. Should be a dedicated embed model, e.g. nomic-embed-text. Never set this to your chat model."/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,10" VerticalAlignment="Bottom">
                                <TextBlock Text="ℹ️ Use a dedicated embed model (e.g. nomic-embed-text). Setting your Chat Model here will break RAG." 
                                           Style="{DynamicResource LpMutedLabel}" TextWrapping="Wrap" FontSize="11"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="🛠️  Action-Specific Models" Style="{DynamicResource LpSectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,10">
                                <TextBlock Text="Explain Code Model" Style="{DynamicResource LpLabelStyle}"/>
                                <ComboBox x:Name="CmbExplainModel" Height="28"/></StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="8,0,0,10">
                                <TextBlock Text="Refactor Model" Style="{DynamicResource LpLabelStyle}"/>
                                <ComboBox x:Name="CmbRefactorModel" Height="28"/></StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,8,10">
                                <TextBlock Text="Doc Generation Model" Style="{DynamicResource LpLabelStyle}"/>
                                <ComboBox x:Name="CmbDocModel" Height="28"/></StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="8,0,0,10">
                                <TextBlock Text="Code Review Model" Style="{DynamicResource LpLabelStyle}"/>
                                <ComboBox x:Name="CmbReviewModel" Height="28"/></StackPanel>
                        </Grid>
                        <Button x:Name="BtnRefreshModels" Content="↻  Refresh Model List" Style="{DynamicResource LpSecondaryBtn}" HorizontalAlignment="Left" Click="BtnRefreshModels_Click" Margin="0,2,0,10"/>

                        <!-- Inline Completion Behaviour -->
                        <TextBlock Text="✨  Inline Completion" Style="{DynamicResource LpSectionHeader}"/>
                        <CheckBox x:Name="ChkEnableInline" Content="Enable inline code completion (ghost-text)" Style="{DynamicResource LpCheckStyle}"/>
                        <CheckBox x:Name="ChkShowGhost" Content="Show ghost-text preview while typing" Style="{DynamicResource LpCheckStyle}"/>

                        <!-- Code Actions Visibility -->
                        <TextBlock Text="⚙️  Enabled Code Actions" Style="{DynamicResource LpSectionHeader}"/>
                        <UniformGrid Columns="2" Margin="0,4,0,4">
                            <CheckBox x:Name="ChkExplain"  Content="Explain Code" Style="{DynamicResource LpCheckStyle}"/>
                            <CheckBox x:Name="ChkRefactor" Content="Refactor Code" Style="{DynamicResource LpCheckStyle}"/>
                            <CheckBox x:Name="ChkDocGen"   Content="Generate Documentation" Style="{DynamicResource LpCheckStyle}"/>
                            <CheckBox x:Name="ChkReview"   Content="Code Review" Style="{DynamicResource LpCheckStyle}"/>
                            <CheckBox x:Name="ChkFix"      Content="Fix Issues" Style="{DynamicResource LpCheckStyle}"/>
                            <CheckBox x:Name="ChkUnitTest" Content="Generate Unit Test" Style="{DynamicResource LpCheckStyle}"/>
                        </UniformGrid>

                        <!-- Interface Preferences -->
                        <TextBlock Text="🎨  Interface" Style="{DynamicResource LpSectionHeader}"/>
                        <CheckBox x:Name="ChkStatusBar" Content="Show LocalPilot status in the status bar" Style="{DynamicResource LpCheckStyle}"/>
                        <CheckBox x:Name="ChkEnableLogging" Content="Enable diagnostic logging" Style="{DynamicResource LpCheckStyle}"/>
                        <Button x:Name="BtnOpenLog" Content="📂  Open Log File" Style="{DynamicResource LpSecondaryBtn}" HorizontalAlignment="Left" Click="BtnOpenLog_Click" Margin="24,4,0,10" Height="28" Padding="12,2"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ───────────────── ADVANCED TAB ───────────────── -->
            <TabItem Header="Advanced">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                    <StackPanel>
                        <!-- Hyperparameters -->
                        <TextBlock Text="🧠  Intelligence Mode" Style="{DynamicResource LpSectionHeader}"/>
                        <TextBlock Text="Select a preset to automatically optimize generator parameters, or adjust them individually to use 'Custom' mode." 
                                   Style="{DynamicResource LpMutedLabel}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <ComboBox x:Name="CmbPerformanceMode" Height="32" Margin="0,0,0,20" SelectionChanged="CmbPerformanceMode_SelectionChanged">
                            <ComboBoxItem Content="Fast (High speed, creative)"/>
                            <ComboBoxItem Content="Standard (Balanced)"/>
                            <ComboBoxItem Content="High Accuracy (Strict, precise)"/>
                        </ComboBox>

                        <TextBlock Text="🛠️  Autonomous Optimization" Style="{DynamicResource LpSectionHeader}"/>
                        <TextBlock Text="LocalPilot now automatically manages context windows, temperature, and response lengths based on your selected Intelligence Mode and the specific task complexity. Manual overrides have been deprecated for maximum autonomy." 
                                   Style="{DynamicResource LpMutedLabel}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <!-- Inference Limits -->
                        <TextBlock Text="⚡  Inference Limits" Style="{DynamicResource LpSectionHeader}"/>
                        <TextBlock Text="Tune these for your hardware. Lower values = faster first-token and less RAM. Raise them only if responses feel truncated." 
                                   Style="{DynamicResource LpMutedLabel}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Context Window (num_ctx tokens)" Style="{DynamicResource LpLabelStyle}"/>
                                <TextBox x:Name="TxtNumCtx" Style="{DynamicResource LpInputStyle}" ToolTip="KV-cache size. 4096 = fast + low RAM. 8192 = larger context but slower prefill. Recommended: 4096 for CPU-only machines."/>
                                <TextBlock Text="Recommended: 4096 for CPU-only · 8192 for GPU" Style="{DynamicResource LpMutedLabel}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Max Output Tokens (num_predict)" Style="{DynamicResource LpLabelStyle}"/>
                                <TextBox x:Name="TxtNumPredict" Style="{DynamicResource LpInputStyle}" ToolTip="Max tokens the model will generate per response. 1024 is enough for most tasks. Raise to 2048+ for long file generation."/>
                                <TextBlock Text="Recommended: 1024 for chat · 2048 for long generation" Style="{DynamicResource LpMutedLabel}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Max Chat History Messages" Style="{DynamicResource LpLabelStyle}"/>
                                <TextBox x:Name="TxtChatHistory" Style="{DynamicResource LpInputStyle}" ToolTip="Max number of past messages to retain in conversation context."/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Request Timeout (seconds)" Style="{DynamicResource LpLabelStyle}"/>
                                <TextBox x:Name="TxtRequestTimeout" Style="{DynamicResource LpInputStyle}" ToolTip="Set connection timeout in seconds. 0 uses automatic dynamic calculation. Set high (e.g. 1800+) for slow CPU execution or deep reasoning."/>
                                <TextBlock Text="Set to 0 for automatic dynamic timeout" Style="{DynamicResource LpMutedLabel}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Project Intelligence -->
                        <TextBlock Text="📂  Project Intelligence" Style="{DynamicResource LpSectionHeader}"/>
                        <CheckBox x:Name="ChkEnableProjectMap" Content="Enable Project Map (Background indexing of headers)" Style="{DynamicResource LpCheckStyle}"/>
                        
                        <StackPanel Margin="0,10,0,10">
                            <TextBlock Text="Background Indexing Concurrency (Higher = Faster, Lower = More Stable)" Style="{DynamicResource LpLabelStyle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <Slider x:Name="SldConcurrency" Minimum="1" Maximum="10" Value="2" Width="200" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="TxtConcurrency" Text="{Binding ElementName=SldConcurrency, Path=Value}" Style="{DynamicResource LpLabelStyle}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>                        <!-- Prompt Templates -->
                        <TextBlock Text="📝  Instruction Templates" Style="{DynamicResource LpSectionHeader}"/>
                        <TextBlock Text="LocalPilot uses modular Markdown templates for all its instructions. You can edit these files to customize how the agent thinks, explains, and refactors." 
                                   Style="{DynamicResource LpMutedLabel}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                        <Button x:Name="BtnOpenPrompts" Content="📂  Open Prompts Directory" Style="{DynamicResource LpSecondaryBtn}" HorizontalAlignment="Left" Click="BtnOpenPrompts_Click" Margin="0,0,0,20"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- ═══ Footer ════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="2" Margin="24,10,24,20">
            <Separator Style="{DynamicResource LpSepStyle}" Margin="0,0,0,16"/>
            <!-- Save Toast Notification -->
            <Border x:Name="SaveToast" Opacity="0" Visibility="Collapsed" Background="{DynamicResource LpMenuBgBrush}" BorderBrush="{DynamicResource LpMenuBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,16">
                <Border.Resources>
                    <Storyboard x:Key="ToastStoryboard">
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                            <LinearDoubleKeyFrame Value="0"  KeyTime="0:0:0.0"/><LinearDoubleKeyFrame Value="1"  KeyTime="0:0:0.25"/>
                            <LinearDoubleKeyFrame Value="1"  KeyTime="0:0:2.25"/><LinearDoubleKeyFrame Value="0"  KeyTime="0:0:2.75"/>
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </Border.Resources>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#1A4EC9B0" CornerRadius="14" Width="28" Height="28" Margin="0,0,10,0">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#4EC9B0" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="ToastTitle" Text="Settings saved" FontWeight="SemiBold" FontSize="12"/><TextBlock x:Name="ToastSubtitle" Text="All changes have been persisted." FontSize="11" Opacity="0.7"/></StackPanel>
                    <Button Grid.Column="2" x:Name="BtnDismissToast" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4" VerticalAlignment="Top" Click="BtnDismissToast_Click"/>
                </Grid>
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾  Save Settings" Style="{DynamicResource LpPrimaryBtn}" x:Name="BtnSave" Click="BtnSave_Click" Width="140"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
